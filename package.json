{
  "name": "rocketboard",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/validate-build-env.mjs && npm run typecheck && vite build && npm run mcp:build",
    "mcp:build": "tsc -p packages/mcp-server/tsconfig.json",
    "mcp:setup": "npm run mcp:build && node packages/mcp-server/dist/cli.js setup claude",
    "mcp:serve": "node packages/mcp-server/dist/cli.js serve",
    "mcp:serve:http": "node packages/mcp-server/dist/cli.js serve-http",
    "preview": "vite preview",
    "test": "vitest run",
    "test:e2e:vip": "playwright test e2e/vip-billing.spec.ts",
    "verify": "npm run test && npm run build && npm run check:bundle-budget && npm run check:function-secrets",
    "check:bundle-budget": "node scripts/check-bundle-budget.mjs",
    "check:function-secrets": "node scripts/check-function-secrets-manifest.mjs",
    "check:migrations": "node scripts/check-migrations.mjs",
    "sql:verify:reset": "node scripts/sql-verify-reset.mjs",
    "sql:verify:upgrade": "node scripts/sql-verify-upgrade.mjs",
    "git:status": "node scripts/git-janitor.mjs status",
    "git:cleanup": "node scripts/git-janitor.mjs cleanup",
    "workflow:clean": "pipelane run clean",
    "workflow:devmode": "pipelane run devmode",
    "workflow:new": "pipelane run new",
    "workflow:pr": "pipelane run pr",
    "workflow:merge": "pipelane run merge",
    "workflow:release-check": "pipelane run release-check",
    "workflow:repo-guard": "pipelane run repo-guard",
    "workflow:resume": "pipelane run resume",
    "workflow:task-lock": "pipelane run task-lock",
    "workflow:deploy": "pipelane run deploy",
    "workflow:api": "pipelane run api",
    "pipelane:board": "pipelane board",
    "pipelane:update": "pipelane update",
    "typecheck": "tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p packages/mcp-server/tsconfig.json",
    "db:types": "supabase gen types --local --lang=typescript 2>/dev/null > src/platform/supabase/database.types.ts",
    "pipelane:setup": "pipelane setup",
    "pipelane:configure": "pipelane configure",
    "pipelane:devmode": "pipelane run devmode",
    "pipelane:new": "pipelane run new",
    "pipelane:resume": "pipelane run resume",
    "pipelane:pr": "pipelane run pr",
    "pipelane:merge": "pipelane run merge",
    "pipelane:release-check": "pipelane run release-check",
    "pipelane:task-lock": "pipelane run task-lock",
    "pipelane:deploy": "pipelane run deploy",
    "pipelane:clean": "pipelane run clean",
    "pipelane:api": "pipelane run api",
    "workflow:setup": "pipelane setup",
    "workflow:configure": "pipelane configure",
    "workflow:pipelane": "pipelane board",
    "pipelane:repo-guard": "pipelane run repo-guard",
    "pipelane:status": "pipelane run status",
    "pipelane:doctor": "pipelane run doctor",
    "pipelane:rollback": "pipelane run rollback",
    "pipelane:smoke": "pipelane run smoke"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/space-grotesk": "^5.2.10",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@supabase/supabase-js": "^2.99.3",
    "@tanstack/react-query": "^5.94.5",
    "@tanstack/react-router": "^1.168.1",
    "@tanstack/react-virtual": "^3.13.23",
    "@tiptap/core": "^3.20.4",
    "@tiptap/extension-link": "^3.22.3",
    "@tiptap/extension-placeholder": "^3.20.5",
    "@tiptap/extension-table": "^3.20.5",
    "@tiptap/extension-table-cell": "^3.20.5",
    "@tiptap/extension-table-header": "^3.20.5",
    "@tiptap/extension-table-row": "^3.20.5",
    "@tiptap/extension-task-item": "^3.20.5",
    "@tiptap/extension-task-list": "^3.20.5",
    "@tiptap/react": "^3.20.4",
    "@tiptap/starter-kit": "^3.20.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fflate": "^0.8.2",
    "lucide-react": "^0.577.0",
    "posthog-js": "^1.369.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.27",
    "jsdom": "^27.0.1",
    "pipelane": "github:jokim1/pipelane#9d013cb919787cf5f27cd6ba5253eabf36d34474",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.0.0",
    "vite": "^7.3.2",
    "vitest": "^3.2.4"
  }
}
