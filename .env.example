# Local Supabase:
# VITE_SUPABASE_URL=http://127.0.0.1:54321
# VITE_SUPABASE_PUBLISHABLE_KEY=copy-from-`supabase status -o env`
# Hosted Supabase:
# VITE_SUPABASE_URL=https://your-project-ref.supabase.co
# VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key
# Dev auto-login (local Supabase only):
# VITE_DEV_AUTO_LOGIN=true
# VITE_DEV_AUTO_LOGIN_EMAIL=demo@rocketboard.io
# VITE_DEV_AUTO_LOGIN_PASSWORD=demo-password
# Self-hosted mode (hides billing UI, returns safe fallbacks for Stripe calls):
# VITE_SELF_HOSTED=true
# Error monitoring (PostHog, errors-only — autocapture + pageview disabled):
# VITE_POSTHOG_KEY=phc_...
# VITE_POSTHOG_HOST=https://us.i.posthog.com
# VITE_GIT_SHA=... (injected by deploy-hosted.yml in CI)
# Smoke-test route (/dev/throw) — gated ON in dev by default; set in staging for verification:
# VITE_ALLOW_SMOKE=true
